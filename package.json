{
    "name": "sentinel",
    "private": true,
    "scripts": {
        "build": "tsc",
        "build:spa": "npm run build --prefix frontend/vue",
        "watch": "tsc --watch",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:e2e:fullstack": "playwright test -c playwright.fullstack.config.ts",
        "lint": "eslint . && prettier --check \"tests/**/*.ts\" \"*.{js,ts}\"",
        "lint:fix": "eslint . --fix && prettier --write \"tests/**/*.ts\" \"*.{js,ts}\"",
        "format": "prettier --write \"tests/**/*.ts\" \"*.{js,ts}\"",
        "format:check": "prettier --check \"tests/**/*.ts\" \"*.{js,ts}\"",
        "prepare": "husky"
    },
    "overrides": {
        "@babel/core": "7.29.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.0",
        "@types/jest": "^30.0.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "jiti": "^2.7.0",
        "lint-staged": "^17.0.7",
        "maplibre-gl": "^4.5.0",
        "prettier": "^3.8.3",
        "ts-jest": "^29.4.6",
        "typescript": "^5.4.0",
        "typescript-eslint": "^8.61.0"
    }
}
