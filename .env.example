# Sentinel environment configuration — copy to `.env` (git-ignored) and fill in.
# Only non-default / deployment-specific values need to be set; everything here
# has a working default in backend/config.py.

# ── Digital-decode sidecar (dsd-fme) ──────────────────────────────────────────
# Shared secret authenticating the decoder container's event POSTs to the
# backend. REQUIRED to use digital decode — generate a random value, e.g.
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# The decoder is opt-in (compose `--profile decoder`); see decoder/README.md.
SENTINEL_DECODER_SECRET=

# Radio id the decoder session belongs to (matches a radio in the SDR settings).
SENTINEL_DECODER_RADIO_ID=1
