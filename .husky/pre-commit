# Pre-commit gate — mirror of CI, on staged files only. Blocks the commit if
# formatting/lint fails. Two lint-staged passes because the repo has two npm
# contexts with separate ESLint/Prettier config and node_modules.
set -e

# Vue SPA — run from the app dir so lint-staged uses the app's ESLint/Prettier
# config and its own node_modules.
(cd frontend/vue && npx lint-staged)

# Root context — helper tests (tests/), backend Python (ruff), root config files.
npx lint-staged
